---
import SocialMediaIcon from './Icon.astro'
import LinkedInLogo from '../assets/Logos/LinkedInLogo.svg?raw'
import GithubLogo from '../assets/Logos/GithubLogo.svg?raw'
import GmailLogo from '../assets/Logos/GmailLogo.svg?raw'
import ThemeToggle from './ThemeToggle.astro'
import { LINKS } from '../constants/links'
---

<div
  class="relative bottom-0 w-full flex flex-col items-center gap-8 p-4 h-45 bg-bg text-font"
>
  <div class="flex flex-col items-center gap-2">
    <footer class="">Contact Me</footer>
    <div class="flex flex-row gap-3">
      <SocialMediaIcon
        title="LinkedIn"
        link={LINKS.linkedin}
        rawPath={LinkedInLogo}
        hoverColor="#0A66C2"
        width={8}
        height={8}
      />
      <SocialMediaIcon
        title="Github"
        link={LINKS.github}
        rawPath={GithubLogo}
        hoverColor="#646262"
        width={8}
        height={8}
      />
      <SocialMediaIcon
        title="Gmail"
        link={LINKS.gmail}
        rawPath={GmailLogo}
        hoverColor="#EA4335"
        width={8}
        height={8}
      />
    </div>
  </div>
  <ThemeToggle />
</div>
